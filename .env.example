# ─────────────────────────────────────────────────────────────────────────────
#  TraceData.ai — Environment Variables
#
#  Copy this file to .env and fill in your actual values.
#  NEVER commit .env to git — it is in .gitignore.
#  This file (.env.example) IS committed — it documents all required variables.
#
#  Variable names are agreed by the team. Do not rename without team sign-off.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Async URL — used by FastAPI / SQLAlchemy at runtime (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tracedata

# Sync URL — used by Alembic CLI only (psycopg2 driver)
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/tracedata

# ── Redis ─────────────────────────────────────────────────────────────────────
# Used for: Celery broker, agent conversation memory, LLMRouter rate limiting
REDIS_URL=redis://localhost:6379/0

# ── Kafka ─────────────────────────────────────────────────────────────────────
# Internal broker address when running inside Docker: kafka:29092
# Host access (kafkacat, local dev): localhost:9092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_TELEMETRY=fleet.telemetry

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Required for: Orchestrator intent classification, cross-agent synthesis, RAG
# Model routing is handled by LLMRouter — set limits in OpenAI dashboard too.
OPENAI_API_KEY=

# ── LangSmith ─────────────────────────────────────────────────────────────────
# Required for: distributed LangGraph tracing across all agent nodes (P4 owns)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=tracedata

# ── App ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-before-prod
DEBUG=true

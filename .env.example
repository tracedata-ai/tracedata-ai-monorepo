# ─────────────────────────────────────────────────────────────────────────────
# TraceData AI — Environment Configuration Template
#
# Copy this file to .env at the repo root and fill in real values:
#   cp .env.example .env
#
# This single file is the source of truth for ALL services:
#   - docker-compose (via env_file: - .env)
#   - backend Pydantic settings (loads from repo root automatically)
#   - local dev without docker
#
# NEVER commit .env — it is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── API ───────────────────────────────────────────────────────────────────────
APP_ENV=development                          # development | production
DEBUG=true
SECRET_KEY=changeme-use-openssl-rand-hex-32-in-prod

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: localhost  |  docker-compose overrides this with db:5432 inline
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tracedata

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local dev: localhost  |  docker-compose overrides this with redis:6379 inline
REDIS_URL=redis://localhost:6379/0

# ── Database Seeding ──────────────────────────────────────────────────────────
# true → drops and re-seeds on startup (DEV ONLY)
# false → safe for production
RESET_DB=false

# ── AI / LLM ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GOOGLE_API_KEY=your-google-api-key-here

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
SLACK_WEBHOOK_URL_TRACEDATA_TRIPS=
SLACK_WEBHOOK_URL_OPS_ALERTS=

# ── Smoothness ML Model ───────────────────────────────────────────────────────
# Run scripts/fetch_model_release.py to download the bundle before building.
SMOOTHNESS_MODEL_REPO=tracedata-ai/tracedata-ai-ml
SMOOTHNESS_MODEL_RELEASE_TAG=v.2.0.0.2026155.2
SMOOTHNESS_MODEL_PATH=agents/scoring/model_bundle/model.joblib
SMOOTHNESS_MODEL_SERVING_DIR=agents/scoring/model_bundle/serving

# ── Frontend / Maps ───────────────────────────────────────────────────────────
# Baked into the Next.js JS bundle at docker build time (NEXT_PUBLIC_* vars).
# Also passed as docker-compose build args so local `docker compose up --build` works.
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-public-token-here
NEXT_PUBLIC_OWM_TOKEN=your-openweathermap-token-here

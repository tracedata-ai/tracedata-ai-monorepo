apiVersion: v1
kind: Secret
metadata:
  name: tracedata-api-secret
  namespace: tracedata
  labels:
    app: tracedata-api
    tier: backend
    environment: prod
type: Opaque
stringData:
  SECRET_KEY: CHANGE_ME_BEFORE_DEPLOY
  OPENAI_API_KEY: CHANGE_ME_BEFORE_DEPLOY
  ANTHROPIC_API_KEY: CHANGE_ME_BEFORE_DEPLOY
  GOOGLE_API_KEY: CHANGE_ME_BEFORE_DEPLOY

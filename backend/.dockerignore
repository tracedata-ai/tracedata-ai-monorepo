# ─────────────────────────────────────────────────────────────────────────────
# TraceData Backend — .dockerignore
#
# Prevents unnecessary files from being sent to the Docker build context,
# keeping builds fast and the image lean.
# ─────────────────────────────────────────────────────────────────────────────

# Virtual environment — never copy into Docker (we re-install via uv in the image)
.venv/
venv/

# Python cache — always regenerated by the interpreter
__pycache__/
*.py[cod]
*.pyc
*.pyo
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Environment files — secrets must come from Docker env vars, never baked in
.env
.env.local
.env.*.local

# Test artifacts
.coverage
htmlcov/
tests/

# Dev tooling — not needed at runtime
*.md
.dockerignore

# uv lock cache (the installed .venv is what matters, not the download cache)
.uv/

# Logs directory — log files are written at runtime, never baked into the image
logs/

# ─────────────────────────────────────────────────────────────────────────────
# TraceData Backend — Environment Configuration Template
#
# Copy this file to `.env` in the backend/ directory for local development:
#   cp .env.example .env
#
# NEVER commit the actual `.env` file — it is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# asyncpg connection string (async driver required by SQLAlchemy 2.0)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tracedata

# ── API ───────────────────────────────────────────────────────────────────────
APP_ENV=development         # development | production
API_V1_PREFIX=/api/v1
DEBUG=true

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=changeme-use-openssl-rand-hex-32-in-prod
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Database Seeding ──────────────────────────────────────────────────────────
# RESET_DB=true  → Drops all tables and re-seeds from seed_data.json (DEV ONLY)
# RESET_DB=false → Skips seeding if data already exists (safe for prod)

RESET_DB=false

# ── AI / LLM ─────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your-google-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# ── Redis (Celery broker + result backend) ────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# Local .terraform directory (provider binaries, modules cache)
.terraform/

# State files — never commit state to source control
*.tfstate
*.tfstate.backup
*.tfstate.*.backup

# Variable files may contain secrets
*.tfvars
*.tfvars.json

# Crash and debug logs generated by Terraform
crash.log
crash.*.log

# Override files (used for local dev overrides, not for sharing)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform plan output files (may contain sensitive data)
*.tfplan

# CLI configuration (may contain tokens)
.terraformrc
terraform.rc

# NOTE: .terraform.lock.hcl should be committed — it pins provider versions
# for reproducible runs. Do NOT add it here.
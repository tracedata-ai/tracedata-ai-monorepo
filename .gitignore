# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
*.egg
dist/
build/
.eggs/

# Virtual environments (uv creates .venv inside each service folder)
.venv/
venv/
env/
.coverage.ci.*
# Environment files
.env
.env.local
.env.*.local
!.env.example

# uv lockfile cache
.uv/

# ─── Node / Frontend ─────────────────────────────────────────────────────────
node_modules/
.next/
out/
.turbo/
*.tsbuildinfo

# ─── Docker ──────────────────────────────────────────────────────────────────
docker-compose.override.yml

# ─── IDE ─────────────────────────────────────────────────────────────────────
.idea/
*.suo
*.swp
*.swo
.DS_Store

# ─── Testing ─────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ─── Kubernetes ──────────────────────────────────────────────────────────────
# Plaintext secrets — NEVER commit these.
# Workflow: copy from secret.yaml.example → fill values → run scripts/seal-secrets.sh
k8s/**/secret.yaml
# sealed-secret.yaml files are encrypted by kubeseal and ARE safe to commit.
# (they are not ignored here — commit them after running seal-secrets.sh)

# ─── Misc ────────────────────────────────────────────────────────────────────
*.log
*.sqlite

# ─── Logs directory (keep the dir via .gitkeep, ignore actual log files) ─────
backend/logs/*.log

# ─── Smoothness ML model bundle (downloaded via scripts/fetch_model_release.py) ─
# Track the directory (.gitkeep) but never commit the artifacts themselves.
backend/agents/scoring/model_bundle/*.joblib
backend/agents/scoring/model_bundle/serving/
